---
interface Props {
  title: string;
  date: Date;
  description?: string;
  categories: string[];
  url: string;
}

const { title, date, description, categories, url } = Astro.props;

const formatDate = (d: Date) => {
  return d.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
};
---

<article class="group py-6 border-b border-border-soft last:border-b-0">
  <a href={url} class="block focus:outline-none">
    <h2 class="text-lg font-semibold text-fg group-hover:text-accent transition-colors leading-snug">
      {title}
    </h2>
  </a>
  <div class="flex flex-wrap items-center gap-x-3 gap-y-1.5 mt-2 text-sm text-fg-mute">
    <time datetime={date.toISOString()} class="tabular-nums">
      {formatDate(date)}
    </time>
    {categories.length > 0 && (
      <div class="flex items-center gap-1.5">
        {categories.map(cat => (
          <span class="px-2 py-0.5 text-xs rounded-full bg-accent-soft text-accent font-medium">
            {cat}
          </span>
        ))}
      </div>
    )}
  </div>
  {description && (
    <p class="mt-2 text-sm text-fg-mute line-clamp-2 leading-relaxed">
      {description}
    </p>
  )}
</article>
