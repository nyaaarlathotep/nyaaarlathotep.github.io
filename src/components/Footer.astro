---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border-soft mt-20">
  <div class="max-w-4xl mx-auto px-6 py-8 flex flex-col items-center gap-3 text-sm text-fg-mute">
    <div class="flex items-center gap-2">
      <span>&copy; 2022 - {currentYear}</span>
      <a
        href="https://github.com/nyaaarlathotep"
        target="_blank"
        rel="noopener noreferrer"
        class="text-accent hover:text-accent-fg hover:underline transition-colors"
      >
        nyaaar
      </a>
    </div>
    <div id="busuanzi-stats" class="hidden items-center gap-4 text-xs">
      <span>
        本站总访问量 <span id="busuanzi_value_site_pv">-</span> 次
      </span>
      <span>
        本站访客数 <span id="busuanzi_value_site_uv">-</span> 人
      </span>
    </div>
    <div class="text-xs">
      Powered by
      <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">Astro</a>
    </div>
  </div>
</footer>

<script is:inline>
  /**
   * Busuanzi (不蒜子) loader — best-effort, fail silently.
   *
   * Known issues we tolerate:
   *   - jsonp endpoint occasionally returns HTTP 4xx (browsers won't run
   *     the script) → retry once, then give up.
   *   - Ad-blockers (uBlock / AdGuard / Brave Shields) classify the
   *     domain as a tracker and block with ERR_BLOCKED_BY_CLIENT
   *     → onerror fires, we stop retrying and remember the block in
   *     sessionStorage so other pages don't re-trigger the blocker.
   *   - The site domain (nyaaarlathotep.github.io, 24 chars) exceeds
   *     busuanzi's official 22-char limit, so the service may stop
   *     returning data at any time. The container stays hidden in
   *     that case.
   */
  (function () {
    const container = document.getElementById('busuanzi-stats');
    const pvEl = document.getElementById('busuanzi_value_site_pv');
    const uvEl = document.getElementById('busuanzi_value_site_uv');
    if (!container || !pvEl || !uvEl) return;

    // Skip entirely if a previous request was blocked in this session.
    try {
      if (sessionStorage.getItem('busuanzi-blocked') === '1') return;
    } catch (_) {}

    const MAX_ATTEMPTS = 2;
    const TIMEOUT_MS = 2500;
    let attempts = 0;

    function call() {
      attempts++;
      const cbName = 'BusuanziCallback_' + Math.floor(Math.random() * 1e12);
      const s = document.createElement('script');
      let done = false;

      const cleanup = () => {
        try { delete window[cbName]; } catch (_) { window[cbName] = undefined; }
        if (s.parentNode) s.parentNode.removeChild(s);
      };

      const timer = setTimeout(() => {
        if (done) return;
        done = true;
        cleanup();
        if (attempts < MAX_ATTEMPTS) call();
      }, TIMEOUT_MS);

      window[cbName] = function (data) {
        if (done) return;
        done = true;
        clearTimeout(timer);
        cleanup();
        if (data && (data.site_pv || data.site_uv)) {
          pvEl.textContent = data.site_pv ?? '-';
          uvEl.textContent = data.site_uv ?? '-';
          container.classList.remove('hidden');
          container.classList.add('flex');
        }
      };

      // onerror = network failure / ERR_BLOCKED_BY_CLIENT.
      // Don't retry — the blocker would just block the next attempt too.
      s.onerror = () => {
        if (done) return;
        done = true;
        clearTimeout(timer);
        cleanup();
        try { sessionStorage.setItem('busuanzi-blocked', '1'); } catch (_) {}
      };

      s.src = 'https://busuanzi.ibruce.info/busuanzi?jsonpCallback=' + cbName;
      s.referrerPolicy = 'no-referrer-when-downgrade';
      document.head.appendChild(s);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', call);
    } else {
      call();
    }
  })();
</script>
