---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border-soft mt-20">
  <div class="max-w-4xl mx-auto px-6 py-8 flex flex-col items-center gap-3 text-sm text-fg-mute">
    <div class="flex items-center gap-2">
      <span>&copy; 2022 - {currentYear}</span>
      <a
        href="https://github.com/nyaaarlathotep"
        target="_blank"
        rel="noopener noreferrer"
        class="text-accent hover:text-accent-fg hover:underline transition-colors"
      >
        nyaaar
      </a>
    </div>
    <div id="busuanzi-stats" class="hidden flex items-center gap-4 text-xs">
      <span>
        本站总访问量 <span id="busuanzi_value_site_pv">-</span> 次
      </span>
      <span>
        本站访客数 <span id="busuanzi_value_site_uv">-</span> 人
      </span>
    </div>
    <div class="text-xs">
      Powered by
      <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">Astro</a>
    </div>
  </div>
</footer>

<script is:inline>
  /**
   * Busuanzi (不蒜子) loader.
   *
   * The official endpoint at busuanzi.ibruce.info is intermittently flaky —
   * sometimes returns HTTP 4xx for the jsonp endpoint, in which case the
   * browser refuses to execute the script and the counters stay as "-".
   *
   * We:
   *   1. fire a manual jsonp request so we can detect failure and retry
   *   2. only reveal the stats container when a real value arrives
   *   3. retry once on failure (covers the intermittent 404)
   */
  (function () {
    const container = document.getElementById('busuanzi-stats');
    const pvEl = document.getElementById('busuanzi_value_site_pv');
    const uvEl = document.getElementById('busuanzi_value_site_uv');
    if (!container || !pvEl || !uvEl) return;

    let attempts = 0;
    const MAX_ATTEMPTS = 3;

    function call() {
      attempts++;
      const cbName = 'BusuanziCallback_' + Math.floor(Math.random() * 1e12);
      const timer = setTimeout(onFail, 6000);

      window[cbName] = function (data) {
        clearTimeout(timer);
        try {
          if (data && (data.site_pv || data.site_uv)) {
            pvEl.textContent = data.site_pv ?? '-';
            uvEl.textContent = data.site_uv ?? '-';
            container.classList.remove('hidden');
            container.classList.add('flex');
          } else {
            onFail();
          }
        } finally {
          delete window[cbName];
          if (s.parentNode) s.parentNode.removeChild(s);
        }
      };

      function onFail() {
        try { delete window[cbName]; } catch (_) {}
        if (s.parentNode) s.parentNode.removeChild(s);
        if (attempts < MAX_ATTEMPTS) {
          setTimeout(call, 1500);
        }
      }

      const s = document.createElement('script');
      s.src = 'https://busuanzi.ibruce.info/busuanzi?jsonpCallback=' + cbName;
      s.referrerPolicy = 'no-referrer-when-downgrade';
      s.onerror = onFail;
      document.head.appendChild(s);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', call);
    } else {
      call();
    }
  })();
</script>
