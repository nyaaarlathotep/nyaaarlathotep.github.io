---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border-soft mt-20">
  <div class="max-w-4xl mx-auto px-6 py-8 flex flex-col items-center gap-3 text-sm text-fg-mute">
    <div class="flex items-center gap-2">
      <span>&copy; 2022 - {currentYear}</span>
      <a
        href="https://github.com/nyaaarlathotep"
        target="_blank"
        rel="noopener noreferrer"
        class="text-accent hover:text-accent-fg hover:underline transition-colors"
      >
        nyaaar
      </a>
    </div>
    <div class="flex items-center gap-4 text-xs">
      <span>
        本站总访问量 <span id="busuanzi_value_site_pv">-</span> 次
      </span>
      <span>
        本站访客数 <span id="busuanzi_value_site_uv">-</span> 人
      </span>
    </div>
    <div class="text-xs">
      Powered by
      <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">Astro</a>
    </div>
  </div>
</footer>

<script async src="//busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"></script>
