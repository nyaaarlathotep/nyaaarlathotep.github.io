---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - 页面未找到">
  <div class="max-w-3xl mx-auto px-6 py-24 text-center">
    <h1 class="text-7xl md:text-8xl font-bold text-fg tracking-tight mb-4">404</h1>
    <p class="text-lg text-fg-mute mb-10">页面不存在，或许它已经飞向了远方。</p>
    <a
      href="/"
      class="inline-block px-6 py-2.5 bg-fg text-bg rounded-md font-medium hover:bg-accent hover:text-bg transition-colors"
    >
      返回首页
    </a>
  </div>
</BaseLayout>
