---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - 页面未找到">
  <div class="max-w-3xl mx-auto px-6 py-24 text-center">
    <h1 class="text-6xl font-bold text-[#18181B] mb-4">404</h1>
    <p class="text-xl text-[#6B7280] mb-8">页面不存在</p>
    <a
      href="/"
      class="inline-block px-6 py-3 bg-[#18181B] text-white rounded-lg font-medium hover:bg-[#3B82F6] transition-colors duration-200"
    >
      返回首页
    </a>
  </div>
</BaseLayout>
