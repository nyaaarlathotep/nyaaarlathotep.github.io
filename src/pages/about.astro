---
import BaseLayout from '../layouts/BaseLayout.astro';
import { social } from '../data/social';
import { skills } from '../data/skills';
---

<BaseLayout title="关于" description="少摸鱼，多学习">
  <div class="max-w-3xl mx-auto px-6 py-12">
    <h1 class="text-3xl md:text-4xl font-bold text-fg tracking-tight mb-8">关于</h1>

    <div class="prose">
      <p>少摸鱼，多学习。</p>
      <p>博客内容是自己对学习内容的再整理，如果有错误请叫下我。</p>
    </div>

    <section class="mt-12">
      <h2 class="text-xl font-semibold text-fg mb-4">联系</h2>
      <ul class="space-y-2">
        {social.map(item => (
          <li class="text-fg-mute">
            <span class="font-medium text-fg">{item.sitename}</span>：
            <a
              href={item.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-accent hover:text-accent-fg hover:underline transition-colors"
            >
              @{item.name}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-12">
      <h2 class="text-xl font-semibold text-fg mb-4">Skill Keywords</h2>
      <div class="space-y-5">
        {skills.map(group => (
          <div>
            <h3 class="text-base font-medium text-fg mb-2.5">{group.name}</h3>
            <div class="flex flex-wrap gap-2">
              {group.keywords.map(keyword => (
                <span class="px-3 py-1 text-sm rounded-full border border-border text-fg-mute hover:border-accent hover:text-accent transition-colors">
                  {keyword}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <p class="mt-12 text-xs text-fg-mute">
      <a href="https://www.flaticon.com/free-icons/magpie" title="magpie icons" class="hover:text-accent hover:underline transition-colors">
        Magpie icons created by bsd - Flaticon
      </a>
    </p>
  </div>
</BaseLayout>
