---
import BaseLayout from './BaseLayout.astro';
import Comments from '../components/Comments.astro';

interface Props {
  title: string;
  date: Date;
  categories: string[];
  description?: string;
}

const { title, date, categories, description } = Astro.props;

const formatDate = (d: Date) => {
  return d.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
};
---

<BaseLayout title={title} description={description}>
  <article class="max-w-3xl mx-auto px-6 py-12">
    <header class="mb-10 pb-6 border-b border-border-soft">
      <h1 class="text-3xl md:text-4xl font-bold text-fg leading-tight tracking-tight">
        {title}
      </h1>
      <div class="flex flex-wrap items-center gap-x-3 gap-y-2 mt-4 text-sm text-fg-mute">
        <time datetime={date.toISOString()} class="tabular-nums">
          {formatDate(date)}
        </time>
        {categories.length > 0 && (
          <div class="flex items-center gap-1.5">
            {categories.map(cat => (
              <a
                href={`/categories/#${cat}`}
                class="px-2.5 py-0.5 text-xs rounded-full bg-accent-soft text-accent font-medium hover:bg-accent/15 transition-colors"
              >
                {cat}
              </a>
            ))}
          </div>
        )}
      </div>
    </header>

    <div class="prose">
      <slot />
    </div>

    <div class="mt-16 pt-8 border-t border-border-soft">
      <Comments />
    </div>
  </article>
</BaseLayout>
