---
import BaseLayout from './BaseLayout.astro';
import Comments from '../components/Comments.astro';

interface Props {
  title: string;
  date: Date;
  categories: string[];
  description?: string;
}

const { title, date, categories, description } = Astro.props;

const formatDate = (d: Date) => {
  return d.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
};
---

<BaseLayout title={title} description={description}>
  <article class="max-w-3xl mx-auto px-6 py-12">
    <header class="mb-10">
      <h1 class="text-3xl font-bold text-[#18181B] leading-tight">
        {title}
      </h1>
      <div class="flex items-center gap-3 mt-4 text-sm text-[#6B7280]">
        <time datetime={date.toISOString()}>
          {formatDate(date)}
        </time>
        {categories.length > 0 && (
          <div class="flex items-center gap-1.5">
            {categories.map(cat => (
              <a
                href={`/categories/#${cat}`}
                class="px-2.5 py-0.5 text-xs rounded-full bg-[#EFF6FF] text-[#3B82F6] font-medium hover:bg-[#DBEAFE] transition-colors duration-200"
              >
                {cat}
              </a>
            ))}
          </div>
        )}
      </div>
    </header>

    <div class="prose">
      <slot />
    </div>

    <Comments />
  </article>
</BaseLayout>
